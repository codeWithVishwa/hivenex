# Copy to .env and adjust
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hivenex
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# The super admin is seeded on first run if no users exist.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-strong

# Cloudinary (optional) — enables image attachments on client status updates.
# Leave unset to disable image uploads; text updates always work.
# CLOUDINARY_CLOUD_NAME=your-cloud
# CLOUDINARY_API_KEY=123456789
# CLOUDINARY_API_SECRET=your-secret
